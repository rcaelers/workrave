msgid "Adds a Workrave icon to the system tray for quick access."
msgstr "Voegt een Workrave-pictogram toe aan het systeemvak voor snelle toegang."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:126
msgid "Launches Workrave automatically when you sign in."
msgstr "Start Workrave automatisch wanneer je je aanmeldt."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:134
msgid "Language used for Workrave's interface."
msgstr "Taal die voor de interface van Workrave wordt gebruikt."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:144
