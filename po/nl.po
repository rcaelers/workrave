msgstr "Licht of donker kleurenschema voor de Workrave-vensters."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:154
msgid "Icon theme"
msgstr "Icoonthema"

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:155
msgid "Visual style used for Workrave's icons."
msgstr "Visuele stijl die voor de Workrave-pictogrammen wordt gebruikt."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:185
msgid "Lock & power"
msgstr "Vergrendelen en energiebeheer"

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:189
msgid "Custom lock command"
msgstr "Aangepaste vergrendelopdracht"

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:190
msgid "Shell command for locking the screen. When set, appears as 'Custom command' in the lock method list."
msgstr "Shellopdracht om het scherm te vergrendelen. Als deze is ingesteld, verschijnt deze als 'Aangepaste opdracht' in de lijst met vergrendelmethoden."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:192
msgid "e.g. /usr/bin/pmset displaysleepnow"
msgstr "bijv. /usr/bin/pmset displaysleepnow"

#
#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:199
msgid "Lock method"
msgstr "Vergrendelmethode"

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:200
msgid "Which screen-lock backend to use when the Lock button is pressed."
msgstr "Welke backend voor schermvergrendeling moet worden gebruikt wanneer op de knop Vergrendelen wordt gedrukt."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:209
msgid "Sleep action"
msgstr "Slaapstandactie"

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:210
msgid "What the Sleep button does — suspend, hibernate, or hybrid sleep."
msgstr "Wat de knop Slaapstand doet — slaapstand, hibernatie of hybride slaapstand."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:222
msgid "Linux display server"
msgstr "Linux-beeldserver"

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:228
msgid "Runs Workrave under XWayland instead of native Wayland. Requires a restart of Workrave."
msgstr "Laat Workrave onder XWayland draaien in plaats van native Wayland. Vereist een herstart van Workrave."

#: ui/app/toolkits/qt/qml/GeneralPrefPage.qml:237
msgid "Uses the Workrave GNOME Shell extension to show break prompts on Wayland. Experimental."
msgstr "Gebruikt de Workrave GNOME Shell-extensie om pauzemeldingen op Wayland te tonen. Experimenteel."

#: ui/app/toolkits/qt/qml/MicroBreakOverlay.qml:182
msgid "Please stop and relax"
msgstr "Stop even en ontspan"

#: ui/app/toolkits/qt/qml/MicrobreakPrefPage.qml:21
msgid "When off, no microbreak prompts will be shown."
msgstr "Als dit uit staat, worden er geen meldingen voor micropauzes getoond."

#: ui/app/toolkits/qt/qml/MicrobreakPrefPage.qml:33
msgid "How long you've been using the keyboard or mouse before being prompted."
msgstr "Hoe lang je het toetsenbord of de muis gebruikt voordat je een melding krijgt."

#: ui/app/toolkits/qt/qml/MicrobreakPrefPage.qml:53
msgid "How long each microbreak lasts."
msgstr "Hoe lang elke micropauze duurt."

#: ui/app/toolkits/qt/qml/MicrobreakPrefPage.qml:95
#: ui/app/toolkits/qt/qml/RestBreakPrefPage.qml:96
msgid "Show a gentle reminder a few seconds before the break starts."
msgstr "Toon enkele seconden voordat de pauze begint een vriendelijke herinnering."

#: ui/app/toolkits/qt/qml/MicrobreakPrefPage.qml:104
#: ui/app/toolkits/qt/qml/RestBreakPrefPage.qml:105
msgid "When off, Workrave keeps reminding you until the break starts."
msgstr "Als dit uit staat, blijft Workrave je herinneren totdat de pauze begint."

